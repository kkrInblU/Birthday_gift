<navigation-bar title="通知中心" back="{{false}}" color="#102A43" background="#F8FAFC"></navigation-bar>

<view class="page">
  <view class="hero-card">
    <view>
      <text class="hero-title">校园通知</text>
      <text class="hero-subtitle">全部通知与订阅通知统一查看</text>
    </view>
    <view class="hero-metric">
      <text class="hero-number">{{unreadCount}}</text>
      <text class="hero-label">未读</text>
    </view>
  </view>

  <view class="search-entry" bindtap="openSearch">
    <text class="search-icon">⌕</text>
    <text class="search-placeholder">搜索通知标题、发布单位、关键词</text>
  </view>

  <view class="toolbar">
    <view class="switch-group">
      <view
        class="switch-item {{activeView === 'all' ? 'switch-item-active' : ''}}"
        bindtap="switchView"
        data-view="all"
      >全部通知</view>
      <view
        class="switch-item {{activeView === 'subscribed' ? 'switch-item-active' : ''}}"
        bindtap="switchView"
        data-view="subscribed"
      >订阅通知</view>
    </view>
    <view class="refresh-btn" bindtap="refreshPage">{{loading ? '刷新中' : '刷新'}}</view>
  </view>

  <view class="filter-row">
    <text class="filter-label">适用人群</text>
    <picker
      class="audience-picker"
      mode="selector"
      range="{{audienceOptions}}"
      range-key="label"
      value="{{activeAudienceIndex}}"
      bindchange="changeAudience"
    >
      <view class="audience-picker-inner">
        <text class="audience-picker-text">{{activeAudienceLabel}}</text>
        <text class="audience-picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <text class="sync-time">最近同步：{{lastSync}}</text>
  <view wx:if="{{errorText}}" class="error-box">{{errorText}}</view>

  <scroll-view
    class="list-scroll"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="true"
    bindscrolltolower="loadMore"
  >
    <block wx:for="{{displayedNotifications}}" wx:key="newsId">
      <view class="notice-item {{item.unread ? 'notice-item-unread' : ''}}" bindtap="openDetail" data-news-id="{{item.newsId}}">
        <view class="notice-top">
          <text class="notice-title {{item.unread ? 'notice-title-unread' : ''}}">{{item.title}}</text>
          <text wx:if="{{item.unread}}" class="notice-badge">未读</text>
        </view>
        <view class="notice-meta-row">
          <text class="notice-department">{{item.department}}</text>
          <text class="notice-time">{{item.publishTime}}</text>
        </view>
      </view>
    </block>

    <view wx:if="{{!displayedNotifications.length && !loading}}" class="empty-box">
      <text class="empty-title">{{activeView === 'subscribed' ? '暂无订阅通知' : '暂无通知'}}</text>
      <text class="empty-desc">{{activeView === 'subscribed' ? '先去通知详情页订阅发布单位' : '切换人群或下拉刷新后再试'}}</text>
    </view>

    <view wx:if="{{displayedNotifications.length && displayedNotifications.length < filteredNotifications.length}}" class="more-tip">
      上拉继续加载更多
    </view>
    <view class="bottom-space"></view>
  </scroll-view>
</view>
