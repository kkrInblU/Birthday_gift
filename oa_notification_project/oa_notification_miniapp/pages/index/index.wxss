page {
  height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(15, 118, 110, 0.12), transparent 32%),
    linear-gradient(180deg, #f8fafc 0%, #eef6f5 100%);
}

.page {
  height: calc(100vh - 88rpx);
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0f766e, #155e75);
  color: #ffffff;
  box-shadow: 0 20rpx 50rpx rgba(15, 118, 110, 0.18);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.hero-metric {
  min-width: 132rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
  text-align: center;
}

.hero-number {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.hero-label {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
}

.search-entry {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.06);
}

.search-icon {
  font-size: 28rpx;
  color: #0f766e;
}

.search-placeholder {
  font-size: 24rpx;
  color: #64748b;
}

.toolbar {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.switch-group {
  flex: 1;
  display: flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
}

.switch-item-active {
  background: #0f766e;
  color: #ffffff;
}

.refresh-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #102a43;
  color: #ffffff;
  font-size: 22rpx;
}

.sync-time {
  margin: 16rpx 6rpx 14rpx;
  color: #64748b;
  font-size: 22rpx;
}

.filter-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 0 6rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #334155;
  font-weight: 600;
}

.audience-picker {
  min-width: 220rpx;
}

.audience-picker-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.audience-picker-text {
  font-size: 22rpx;
  color: #0f172a;
  font-weight: 600;
}

.audience-picker-arrow {
  font-size: 18rpx;
  color: #64748b;
}

.error-box {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff1f2;
  color: #be123c;
  font-size: 24rpx;
}

.list-scroll {
  flex: 1;
  min-height: 0;
}

.notice-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
  border: 2rpx solid transparent;
}

.notice-item-unread {
  border-color: rgba(15, 118, 110, 0.18);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 253, 250, 0.98));
}

.notice-top {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.notice-title {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.5;
  color: #0f172a;
}

.notice-title-unread {
  font-weight: 700;
  color: #0f766e;
}

.notice-badge {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 700;
}

.notice-meta-row {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.notice-department,
.notice-time {
  font-size: 22rpx;
  color: #64748b;
}

.notice-department {
  max-width: 48%;
}

.notice-time {
  text-align: right;
}

.empty-box {
  margin-top: 120rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.more-tip {
  padding: 10rpx 0 26rpx;
  text-align: center;
  font-size: 22rpx;
  color: #64748b;
}

.bottom-space {
  height: 32rpx;
}
