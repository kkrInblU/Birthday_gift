<navigation-bar title="搜索通知" back="{{true}}" color="#102A43" background="#F8FAFC"></navigation-bar>

<view class="page">
  <view class="search-box">
    <input class="search-input" placeholder="输入关键词搜索通知" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="runSearch" />
    <view class="search-btn" bindtap="runSearch">搜索</view>
  </view>

  <view class="card">
    <text class="section-title">搜索历史</text>
    <view class="history-wrap">
      <block wx:for="{{history}}" wx:key="*this">
        <view class="history-chip" bindtap="useHistory" data-keyword="{{item}}">{{item}}</view>
      </block>
      <text wx:if="{{!history.length}}" class="history-empty">暂无搜索历史</text>
    </view>
  </view>

  <scroll-view class="result-scroll" scroll-y="true" enhanced="true" show-scrollbar="true">
    <block wx:for="{{resultItems}}" wx:key="newsId">
      <view class="result-card" bindtap="openDetail" data-news-id="{{item.newsId}}">
        <text class="result-title">{{item.title}}</text>
        <text class="result-meta">{{item.department}} | {{item.publishTime}}</text>
      </view>
    </block>
    <view wx:if="{{keyword && !resultItems.length && !loading}}" class="empty-box">暂无匹配结果</view>
    <view class="bottom-space"></view>
  </scroll-view>
</view>
