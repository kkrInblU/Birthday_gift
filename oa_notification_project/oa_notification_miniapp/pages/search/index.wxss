page {
  height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
}

.page {
  height: calc(100vh - 88rpx);
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.search-box {
  display: flex;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.95);
  font-size: 26rpx;
}

.search-btn {
  width: 140rpx;
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  border-radius: 22rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.history-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 22rpx;
}

.history-empty {
  font-size: 22rpx;
  color: #94a3b8;
}

.result-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.result-card {
  margin-bottom: 14rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.95);
}

.result-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.result-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.empty-box {
  margin-top: 120rpx;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}

.bottom-space {
  height: 30rpx;
}
